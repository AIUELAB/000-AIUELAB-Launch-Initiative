# MCP Server API Keys Configuration
# Copy this file to .env.mcp and fill in your actual API keys

# REQUIRED: Core MCP Servers
# GitHub Personal Access Token (required for GitHub MCP)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token_here

# Brave Search API Key (required for web search)
# Get yours at: https://api.search.brave.com/
BRAVE_API_KEY=your_brave_api_key_here

# OPTIONAL: Additional Services
# Firecrawl API Key (for advanced web scraping)
# Get yours at: https://firecrawl.dev/
FIRECRAWL_API_KEY=

# Slack Bot Token (for Slack integration)
# Create app at: https://api.slack.com/apps
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# GitLab Personal Access Token
# Create at: https://gitlab.com/-/profile/personal_access_tokens
GITLAB_TOKEN=
GITLAB_API_URL=https://gitlab.com/api/v4

# Google Maps API Key
# Get yours at: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=

# AWS Credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Google Cloud Platform
GOOGLE_APPLICATION_CREDENTIALS=

# Azure Credentials
AZURE_SUBSCRIPTION_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# LLM Provider Keys (for MCP tools that use LLMs)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Smithery API Key (for MCP server management)
SMITHERY_API_KEY=

# Application Settings
APP_NAME=Claude Code MCP Template
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=False
LOG_LEVEL=INFO