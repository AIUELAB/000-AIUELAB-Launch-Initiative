{
  "name": "Firebase iOS Analytics Automation",
  "description": "iOS アプリの Firebase Analytics データを自動収集・レポート",
  "nodes": [
    {
      "id": "schedule_trigger",
      "type": "schedule",
      "typeVersion": 1,
      "position": [250, 300],
      "schedule": "0 9 * * *",
      "timezone": "Asia/Tokyo"
    },
    {
      "id": "fetch_analytics",
      "type": "http_request",
      "typeVersion": 1,
      "position": [450, 300],
      "requestMethod": "POST",
      "url": "https://analyticsdata.googleapis.com/v1beta/properties/{{ $env.FIREBASE_MEASUREMENT_ID }}:runReport",
      "headers": {
        "Authorization": "Bearer {{ $env.FIREBASE_TOKEN }}",
        "Content-Type": "application/json"
      },
      "body": {
        "dateRanges": [
          {
            "startDate": "yesterday",
            "endDate": "yesterday"
          }
        ],
        "dimensions": [
          { "name": "eventName" },
          { "name": "platform" },
          { "name": "appVersion" }
        ],
        "metrics": [
          { "name": "activeUsers" },
          { "name": "newUsers" },
          { "name": "eventCount" },
          { "name": "screenPageViews" },
          { "name": "sessions" },
          { "name": "averageSessionDuration" }
        ]
      }
    },
    {
      "id": "process_data",
      "type": "function",
      "typeVersion": 1,
      "position": [650, 300],
      "code": "// Analytics データ処理\nconst data = $input.all()[0].json;\nconst report = {\n  date: new Date().toISOString().split('T')[0],\n  summary: {\n    activeUsers: 0,\n    newUsers: 0,\n    sessions: 0,\n    avgDuration: 0\n  },\n  events: [],\n  apps: {}\n};\n\n// データ集計\ndata.rows.forEach(row => {\n  const eventName = row.dimensionValues[0].value;\n  const platform = row.dimensionValues[1].value;\n  const appVersion = row.dimensionValues[2].value;\n  \n  report.summary.activeUsers += parseInt(row.metricValues[0].value);\n  report.summary.newUsers += parseInt(row.metricValues[1].value);\n  report.summary.sessions += parseInt(row.metricValues[4].value);\n  \n  // アプリバージョン別集計\n  if (!report.apps[appVersion]) {\n    report.apps[appVersion] = {\n      users: 0,\n      events: 0\n    };\n  }\n  report.apps[appVersion].users += parseInt(row.metricValues[0].value);\n  report.apps[appVersion].events += parseInt(row.metricValues[2].value);\n});\n\nreturn report;"
    },
    {
      "id": "generate_report",
      "type": "function",
      "typeVersion": 1,
      "position": [850, 300],
      "code": "// レポート生成\nconst report = $input.all()[0].json;\nconst markdown = `\n# 📊 AIUELAB iOS アプリ Analytics レポート\n**日付**: ${report.date}\n\n## 📈 サマリー\n- **アクティブユーザー**: ${report.summary.activeUsers.toLocaleString()}\n- **新規ユーザー**: ${report.summary.newUsers.toLocaleString()}\n- **セッション数**: ${report.summary.sessions.toLocaleString()}\n- **平均セッション時間**: ${Math.round(report.summary.avgDuration / 60)}分\n\n## 📱 アプリバージョン別\n${Object.entries(report.apps).map(([version, data]) => \n  `- **v${version}**: ${data.users} users, ${data.events} events`\n).join('\\n')}\n\n## 🎯 主要イベント\n${report.events.slice(0, 10).map(event => \n  `- ${event.name}: ${event.count.toLocaleString()} 回`\n).join('\\n')}\n\n---\n*Generated by AIUELAB Analytics Automation*\n`;\n\nreturn { markdown, report };"
    },
    {
      "id": "save_to_firestore",
      "type": "firebase",
      "typeVersion": 1,
      "position": [1050, 200],
      "operation": "create",
      "collection": "analytics_reports",
      "document": {
        "date": "{{ $json.report.date }}",
        "data": "{{ $json.report }}",
        "created_at": "{{ $now }}"
      }
    },
    {
      "id": "send_report",
      "type": "email",
      "typeVersion": 1,
      "position": [1050, 400],
      "fromEmail": "analytics@aiuelab.com",
      "toEmail": "aiuelab.official@gmail.com",
      "subject": "📊 Daily iOS Analytics Report - {{ $json.report.date }}",
      "html": "{{ $json.markdown }}",
      "attachments": [
        {
          "filename": "analytics_{{ $json.report.date }}.json",
          "content": "{{ JSON.stringify($json.report, null, 2) }}"
        }
      ]
    },
    {
      "id": "post_to_slack",
      "type": "slack",
      "typeVersion": 1,
      "position": [1050, 600],
      "webhookUrl": "{{ $env.SLACK_WEBHOOK_URL }}",
      "text": "📊 iOS Analytics レポート",
      "blocks": [
        {
          "type": "section",
          "text": {
            "type": "mrkdwn",
            "text": "*Daily Analytics Report*\\n日付: {{ $json.report.date }}"
          }
        },
        {
          "type": "section",
          "fields": [
            {
              "type": "mrkdwn",
              "text": "*アクティブユーザー*\\n{{ $json.report.summary.activeUsers }}"
            },
            {
              "type": "mrkdwn",
              "text": "*新規ユーザー*\\n{{ $json.report.summary.newUsers }}"
            },
            {
              "type": "mrkdwn",
              "text": "*セッション数*\\n{{ $json.report.summary.sessions }}"
            },
            {
              "type": "mrkdwn",
              "text": "*平均時間*\\n{{ Math.round($json.report.summary.avgDuration / 60) }}分"
            }
          ]
        }
      ]
    }
  ],
  "connections": {
    "schedule_trigger": {
      "main": [
        [
          {
            "node": "fetch_analytics",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "fetch_analytics": {
      "main": [
        [
          {
            "node": "process_data",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "process_data": {
      "main": [
        [
          {
            "node": "generate_report",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "generate_report": {
      "main": [
        [
          {
            "node": "save_to_firestore",
            "type": "main",
            "index": 0
          },
          {
            "node": "send_report",
            "type": "main",
            "index": 0
          },
          {
            "node": "post_to_slack",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
