# X (Twitter) API 設定
# アカウント: @AIUELAB

# === 重要: セキュリティ警告 ===
# このファイルをコピーして .env.twitter を作成し、
# 実際の認証情報を入力してください。
# .env.twitter は絶対にGitにコミットしないでください！

# Twitter/X アカウント
TWITTER_USERNAME=AIUELAB
TWITTER_EMAIL=aiuelab.official@gmail.com

# API認証 (https://developer.twitter.com)
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here
TWITTER_BEARER_TOKEN=your_bearer_token_here

# OAuth 2.0 (新しいアプリ用)
TWITTER_CLIENT_ID=your_client_id_here
TWITTER_CLIENT_SECRET=your_client_secret_here

# セッション管理
TWITTER_SESSION_TIMEOUT=3600
TWITTER_AUTO_REFRESH=true

# 投稿設定
TWITTER_AUTO_POST=false
TWITTER_POST_SCHEDULE=0 9,15,21 * * *  # 9時、15時、21時に投稿

# === パスワード管理 ===
# パスワードは暗号化して保存することを推奨
# 以下のコマンドで暗号化:
# python scripts/encrypt_password.py
# TWITTER_PASSWORD_ENCRYPTED=<encrypted_value>
