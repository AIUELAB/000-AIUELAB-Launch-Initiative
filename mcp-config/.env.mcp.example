# MCP Servers Environment Variables
# このファイルを.env.mcpにコピーして、実際のAPIキーを設定してください

# GitHub (必須)
# https://github.com/settings/tokens から取得
GITHUB_TOKEN=your_github_personal_access_token_here

# Brave Search (推奨)
# https://brave.com/search/api/ から取得
BRAVE_API_KEY=your_brave_api_key_here

# Firecrawl (オプショナル)
# https://firecrawl.dev/ から取得
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Slack (オプショナル)
# https://api.slack.com/apps でアプリを作成
SLACK_BOT_TOKEN=your_slack_bot_token_here
SLACK_TEAM_ID=your_slack_team_id_here

# GitLab (オプショナル)
# GitLab Settings > Access Tokens から取得
GITLAB_TOKEN=your_gitlab_token_here
GITLAB_API_URL=https://gitlab.com/api/v4

# Google Maps (オプショナル)
# https://console.cloud.google.com/ から取得
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# AWS (オプショナル)
# AWS IAMコンソールから取得
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# Google Cloud Platform (オプショナル)
# サービスアカウントのJSONファイルパス
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Azure (オプショナル)
# Azure Portalから取得
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id_here
AZURE_CLIENT_ID=your_azure_client_id_here
AZURE_CLIENT_SECRET=your_azure_client_secret_here
AZURE_TENANT_ID=your_azure_tenant_id_here

# OpenAI (オプショナル - 一部のMCPサーバーで使用)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (オプショナル - 一部のMCPサーバーで使用)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Smithery (オプショナル)
# https://smithery.ai/ から取得
SMITHERY_API_KEY=your_smithery_api_key_here
