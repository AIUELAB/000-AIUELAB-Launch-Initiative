{
  "name": "remote",
  "description": "Remote-only MCP servers configuration for cloud-native development",
  "mcpServers": {
    "linear-remote": {
      "transport": "sse",
      "url": "https://mcp.linear.app/sse",
      "headers": {
        "Authorization": "Bearer ${LINEAR_API_KEY}"
      },
      "description": "Linear issue tracking (remote SSE)"
    },
    
    "notion-remote": {
      "transport": "http",
      "url": "https://api.notion.com/v1/mcp",
      "oauth": {
        "clientId": "${NOTION_CLIENT_ID}",
        "clientSecret": "${NOTION_CLIENT_SECRET}",
        "scope": "read_content write_content",
        "authorizationUrl": "https://api.notion.com/v1/oauth/authorize",
        "tokenEndpoint": "https://api.notion.com/v1/oauth/token"
      },
      "headers": {
        "Notion-Version": "2022-06-28"
      },
      "description": "Notion workspace (remote HTTP + OAuth)"
    },
    
    "sentry-remote": {
      "transport": "sse",
      "url": "https://sentry.io/api/mcp/sse",
      "headers": {
        "Authorization": "Bearer ${SENTRY_AUTH_TOKEN}"
      },
      "description": "Sentry error tracking (remote SSE)"
    },
    
    "apidog-remote": {
      "transport": "http",
      "url": "https://api.apidog.com/mcp",
      "headers": {
        "X-API-Key": "${APIDOG_API_KEY}"
      },
      "description": "API documentation (remote HTTP)"
    },
    
    "simplescraper-remote": {
      "transport": "sse",
      "url": "https://api.simplescraper.io/mcp/sse",
      "headers": {
        "X-API-Key": "${SIMPLESCRAPER_API_KEY}"
      },
      "description": "Web scraping service (remote SSE)"
    },
    
    "github-remote": {
      "transport": "sse",
      "url": "https://api.github.com/mcp/sse",
      "headers": {
        "Authorization": "token ${GITHUB_TOKEN}"
      },
      "description": "GitHub API (remote SSE)"
    },
    
    "slack-remote": {
      "transport": "http",
      "url": "https://slack.com/api/mcp",
      "headers": {
        "Authorization": "Bearer ${SLACK_BOT_TOKEN}"
      },
      "description": "Slack workspace (remote HTTP)"
    },
    
    "custom-api": {
      "transport": "http",
      "url": "${CUSTOM_MCP_URL}",
      "headers": {
        "X-API-Key": "${CUSTOM_API_KEY}",
        "X-Client-ID": "${CUSTOM_CLIENT_ID}"
      },
      "tlsVerify": true,
      "timeout": 30000,
      "description": "Custom internal API (remote HTTP)"
    }
  },
  
  "settings": {
    "preferRemoteOverLocal": true,
    "maxConcurrentConnections": 10,
    "connectionTimeout": 30000,
    "enableMetrics": true,
    "logLevel": "info"
  },
  
  "transportSettings": {
    "sse": {
      "reconnectDelay": 5000,
      "maxReconnectAttempts": 10,
      "heartbeatInterval": 30000,
      "bufferSize": 65536
    },
    "http": {
      "requestTimeout": 30000,
      "maxConcurrentRequests": 5,
      "retryOn5xx": true,
      "keepAlive": true,
      "compression": "gzip"
    }
  },
  
  "securitySettings": {
    "validateOrigin": true,
    "tlsMinVersion": "1.2",
    "dnssecValidation": true,
    "certificatePinning": false
  },
  
  "advantages": [
    "No local server management required",
    "Automatic updates by service providers",
    "Better scalability and reliability",
    "Cross-platform compatibility",
    "OAuth 2.0 authentication support"
  ],
  
  "requirements": [
    "Active internet connection",
    "Valid API keys or OAuth credentials",
    "Claude Pro/Max/Team/Enterprise subscription"
  ]
}