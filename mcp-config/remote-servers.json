{
    "remoteMcpServers": {
        "linear": {
            "transport": "sse",
            "url": "https://mcp.linear.app/sse",
            "description": "Linear issue tracking and project management",
            "authentication": {
                "type": "oauth2",
                "scope": "read write issues:read issues:write",
                "tokenEndpoint": "https://api.linear.app/oauth/token"
            },
            "headers": {
                "Authorization": "Bearer ${LINEAR_API_KEY}"
            },
            "capabilities": [
                "issue_management",
                "project_tracking",
                "roadmap_planning"
            ]
        },
        "notion": {
            "transport": "http",
            "url": "https://api.notion.com/v1/mcp",
            "description": "Notion workspace and knowledge base",
            "authentication": {
                "type": "oauth2",
                "clientId": "${NOTION_CLIENT_ID}",
                "clientSecret": "${NOTION_CLIENT_SECRET}",
                "scope": "read_content write_content",
                "authorizationUrl": "https://api.notion.com/v1/oauth/authorize",
                "tokenEndpoint": "https://api.notion.com/v1/oauth/token"
            },
            "headers": {
                "Notion-Version": "2022-06-28"
            },
            "capabilities": [
                "database_queries",
                "page_creation",
                "content_search"
            ]
        },
        "sentry": {
            "transport": "sse",
            "url": "https://sentry.io/api/mcp/sse",
            "description": "Error tracking and performance monitoring",
            "authentication": {
                "type": "bearer",
                "token": "${SENTRY_AUTH_TOKEN}"
            },
            "headers": {
                "Authorization": "Bearer ${SENTRY_AUTH_TOKEN}"
            },
            "capabilities": [
                "error_tracking",
                "performance_monitoring",
                "release_management"
            ]
        },
        "apidog": {
            "transport": "http",
            "url": "https://api.apidog.com/mcp",
            "description": "API documentation and testing",
            "authentication": {
                "type": "api_key",
                "header": "X-API-Key",
                "value": "${APIDOG_API_KEY}"
            },
            "capabilities": ["api_documentation", "api_testing", "mock_servers"]
        },
        "simplescraper": {
            "transport": "sse",
            "url": "https://api.simplescraper.io/mcp/sse",
            "description": "Web scraping and data extraction",
            "authentication": {
                "type": "api_key",
                "header": "X-API-Key",
                "value": "${SIMPLESCRAPER_API_KEY}"
            },
            "capabilities": [
                "web_scraping",
                "data_extraction",
                "scheduled_scraping"
            ]
        },
        "custom_internal": {
            "transport": "http",
            "url": "${CUSTOM_MCP_URL}",
            "description": "Custom internal MCP server",
            "authentication": {
                "type": "custom",
                "headers": {
                    "X-API-Key": "${CUSTOM_API_KEY}",
                    "X-Client-ID": "${CUSTOM_CLIENT_ID}"
                }
            },
            "tlsVerify": true,
            "timeout": 30000,
            "retryPolicy": {
                "maxRetries": 3,
                "backoffMs": 1000
            }
        }
    },
    "transportSettings": {
        "sse": {
            "reconnectDelay": 5000,
            "maxReconnectAttempts": 10,
            "heartbeatInterval": 30000
        },
        "http": {
            "requestTimeout": 30000,
            "maxConcurrentRequests": 5,
            "retryOn5xx": true
        }
    },
    "securitySettings": {
        "validateOrigin": true,
        "allowedOrigins": [
            "https://*.linear.app",
            "https://*.notion.so",
            "https://*.sentry.io",
            "https://*.apidog.com",
            "https://*.simplescraper.io"
        ],
        "dnssecValidation": true,
        "tlsMinVersion": "1.2"
    }
}
