{
  "mcpServers": {
    "comment": "Hybrid configuration with both local and remote MCP servers",
    
    "// Local Servers": "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━",
    
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena-mcp-server",
        "--project",
        "/Users/admin/Documents/Cursor/claude-code-template-mcp"
      ],
      "env": {}
    },
    
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/admin/Documents"
      ],
      "env": {}
    },
    
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    
    "// Remote SSE Servers": "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━",
    
    "linear-remote": {
      "transport": "sse",
      "url": "https://mcp.linear.app/sse",
      "headers": {
        "Authorization": "Bearer ${LINEAR_API_KEY}"
      },
      "description": "Linear issue tracking (remote SSE)"
    },
    
    "sentry-remote": {
      "transport": "sse",
      "url": "https://sentry.io/api/mcp/sse",
      "headers": {
        "Authorization": "Bearer ${SENTRY_AUTH_TOKEN}"
      },
      "description": "Sentry error tracking (remote SSE)"
    },
    
    "simplescraper-remote": {
      "transport": "sse",
      "url": "https://api.simplescraper.io/mcp/sse",
      "headers": {
        "X-API-Key": "${SIMPLESCRAPER_API_KEY}"
      },
      "description": "Web scraping service (remote SSE)"
    },
    
    "// Remote HTTP Servers": "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━",
    
    "notion-remote": {
      "transport": "http",
      "url": "https://api.notion.com/v1/mcp",
      "oauth": {
        "clientId": "${NOTION_CLIENT_ID}",
        "clientSecret": "${NOTION_CLIENT_SECRET}",
        "scope": "read_content write_content",
        "authorizationUrl": "https://api.notion.com/v1/oauth/authorize",
        "tokenEndpoint": "https://api.notion.com/v1/oauth/token"
      },
      "headers": {
        "Notion-Version": "2022-06-28"
      },
      "description": "Notion workspace (remote HTTP + OAuth)"
    },
    
    "apidog-remote": {
      "transport": "http",
      "url": "https://api.apidog.com/mcp",
      "headers": {
        "X-API-Key": "${APIDOG_API_KEY}"
      },
      "description": "API documentation (remote HTTP)"
    },
    
    "custom-api": {
      "transport": "http",
      "url": "${CUSTOM_MCP_URL}",
      "headers": {
        "X-API-Key": "${CUSTOM_API_KEY}",
        "X-Client-ID": "${CUSTOM_CLIENT_ID}"
      },
      "tlsVerify": true,
      "timeout": 30000,
      "description": "Custom internal API (remote HTTP)"
    },
    
    "// Hybrid Servers (Local + Remote fallback)": "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━",
    
    "github-hybrid": {
      "primary": {
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-github"
        ],
        "env": {
          "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
        }
      },
      "fallback": {
        "transport": "sse",
        "url": "https://api.github.com/mcp/sse",
        "headers": {
          "Authorization": "token ${GITHUB_TOKEN}"
        }
      },
      "description": "GitHub with remote fallback"
    },
    
    "// Other Local Servers": "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━",
    
    "brave-search": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    },
    
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ],
      "env": {}
    },
    
    "firecrawl": {
      "command": "uvx",
      "args": [
        "firecrawl-mcp-server"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      }
    }
  },
  
  "globalSettings": {
    "maxConcurrentServers": 10,
    "connectionTimeout": 30000,
    "logLevel": "info",
    "enableMetrics": true
  },
  
  "remoteServerSettings": {
    "sse": {
      "reconnectDelay": 5000,
      "maxReconnectAttempts": 10,
      "heartbeatInterval": 30000,
      "bufferSize": 65536
    },
    "http": {
      "requestTimeout": 30000,
      "maxConcurrentRequests": 5,
      "retryOn5xx": true,
      "keepAlive": true
    },
    "oauth": {
      "tokenRefreshBuffer": 300,
      "storageProvider": "secure-keychain"
    }
  }
}