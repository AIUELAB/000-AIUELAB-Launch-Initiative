# Google/NotebookLM 設定
# aiuelab.official@gmail.com アカウント用

# Googleアカウント
GOOGLE_ACCOUNT=aiuelab.official@gmail.com
GOOGLE_AUTHUSER=1

# NotebookLM
NOTEBOOKLM_NOTEBOOK_ID=ce4eebd7-38da-4b35-8205-8b31f9125827
NOTEBOOKLM_URL=https://notebooklm.google.com/notebook/ce4eebd7-38da-4b35-8205-8b31f9125827?authuser=1

# Google OAuth (必要な場合)
# Google Cloud Console で作成: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8080/callback

# Chrome Profile Path (自動ログイン用)
# macOS: ~/Library/Application Support/Google/Chrome/
CHROME_PROFILE_PATH=~/Library/Application Support/Google/Chrome/Profile 1
CHROME_PROFILE_NAME=AIUELAB

# セッション管理
SESSION_TIMEOUT=3600
AUTO_REFRESH=true
