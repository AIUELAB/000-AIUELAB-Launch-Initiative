# GitHub AIUELAB 設定
# アカウント: https://github.com/AIUELAB

# GitHub認証
GITHUB_USER=AIUELAB
GITHUB_EMAIL=aiuelab.official@gmail.com
GITHUB_TOKEN=your_personal_access_token_here

# 取得方法:
# 1. https://github.com/settings/tokens/new
# 2. 以下のスコープを選択:
#    - repo (フルコントロール)
#    - workflow (GitHub Actions)
#    - admin:org (組織管理)
#    - write:packages (パッケージ公開)
#    - delete_repo (リポジトリ削除)
# 3. Generate token をクリック
# 4. トークンをコピーして上記に貼り付け

# GitHub設定
GITHUB_DEFAULT_BRANCH=main
GITHUB_DEFAULT_LICENSE=MIT
GITHUB_DEFAULT_VISIBILITY=private  # public or private

# iOS開発設定
IOS_BUNDLE_ID_PREFIX=com.aiuelab
IOS_DEVELOPER_NAME=AIUELAB
IOS_DEVELOPER_TEAM=YOUR_TEAM_ID

# 自動化設定
AUTO_CREATE_ISSUES=true
AUTO_CREATE_PROJECTS=true
AUTO_RELEASE=false

# Webhook (オプション)
GITHUB_WEBHOOK_SECRET=your_webhook_secret
