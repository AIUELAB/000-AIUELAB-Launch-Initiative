## 📊 Configuration Template

### Feature Configuration
```python
from pydantic import BaseSettings, Field
from typing import Optional

class FeatureConfig(BaseSettings):
    """Configuration for {feature_name}"""
    
    # Required settings
    enabled: bool = Field(True, env="FEATURE_ENABLED")
    api_key: str = Field(..., env="FEATURE_API_KEY")
    
    # Optional settings
    timeout: int = Field(30, env="FEATURE_TIMEOUT", ge=1, le=300)
    retry_count: int = Field(3, env="FEATURE_RETRY_COUNT", ge=0, le=10)
    cache_ttl: int = Field(3600, env="FEATURE_CACHE_TTL")
    
    # Advanced settings
    debug_mode: bool = Field(False, env="FEATURE_DEBUG")
    max_connections: int = Field(100, env="FEATURE_MAX_CONNECTIONS")
    
    class Config:
        env_prefix = "FEATURE_"
        case_sensitive = False
        
    def validate_config(self) -> None:
        """Validate configuration on startup"""
        if self.enabled and not self.api_key:
            raise ValueError("API key required when feature is enabled")
```

