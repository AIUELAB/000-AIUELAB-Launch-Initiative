## 🔄 API Endpoint Template

### REST API Implementation
```python
from fastapi import APIRouter, HTTPException, Depends
from pydantic import BaseModel, Field
from typing import Optional

router = APIRouter(prefix="/api/v1")

class RequestModel(BaseModel):
    """Request model for {endpoint}"""
    field1: str = Field(..., description="Field description")
    field2: Optional[int] = Field(None, ge=0, le=100)
    
    class Config:
        json_schema_extra = {
            "example": {
                "field1": "value",
                "field2": 42
            }
        }

class ResponseModel(BaseModel):
    """Response model for {endpoint}"""
    success: bool
    data: Optional[Dict[str, Any]]
    message: str

@router.post("/{endpoint}", response_model=ResponseModel)
async def {endpoint_function}(
    request: RequestModel,
    current_user: User = Depends(get_current_user)
) -> ResponseModel:
    """
    {Endpoint description}
    
    - **field1**: Required field description
    - **field2**: Optional field description
    
    Returns successful response or error
    """
    try:
        # Input validation
        validate_request(request)
        
        # Business logic
        result = await process_request(request, current_user)
        
        # Return response
        return ResponseModel(
            success=True,
            data=result,
            message="Operation successful"
        )
    except ValidationError as e:
        raise HTTPException(status_code=400, detail=str(e))
    except Exception as e:
        logger.error(f"Endpoint error: {e}")
        raise HTTPException(status_code=500, detail="Internal server error")
```

## 🎨 UI Component Template

### React Component
```typescript
import React, { useState, useEffect, useCallback } from 'react';
import { useQuery, useMutation } from '@tanstack/react-query';

interface ${ComponentName}Props {
  id: string;
  onComplete?: (data: any) => void;
  className?: string;
}

interface ${ComponentName}State {
  loading: boolean;
  error: Error | null;
  data: any | null;
}

export const ${ComponentName}: React.FC<${ComponentName}Props> = ({
  id,
  onComplete,
  className = ''
}) => {
  // State management
  const [state, setState] = useState<${ComponentName}State>({
    loading: false,
    error: null,
    data: null
  });

  // Fetch data
  const { data, isLoading, error } = useQuery({
    queryKey: ['${componentKey}', id],
    queryFn: () => fetchData(id),
    enabled: !!id
  });

  // Handle actions
  const mutation = useMutation({
    mutationFn: (payload: any) => submitData(payload),
    onSuccess: (data) => {
      onComplete?.(data);
    },
    onError: (error) => {
      setState(prev => ({ ...prev, error }));
    }
  });

  const handleSubmit = useCallback((formData: any) => {
    mutation.mutate(formData);
  }, [mutation]);

  // Render states
  if (isLoading) return <LoadingSpinner />;
  if (error) return <ErrorMessage error={error} />;
  if (!data) return <EmptyState />;

  return (
    <div className={\`\${componentName} \${className}\`}>
      {/* Component content */}
      <h2>{data.title}</h2>
      <button onClick={() => handleSubmit(data)}>
        Submit
      </button>
    </div>
  );
};

// Memoized version for performance
export default React.memo(${ComponentName});
```

