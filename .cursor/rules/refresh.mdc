## 📊 Health Checks

### System Health Monitor
```python
class HealthMonitor:
    """Monitor system health and auto-fix issues"""
    
    def __init__(self):
        self.checks = [
            ("Database", self.check_database),
            ("API", self.check_api),
            ("Cache", self.check_cache),
            ("Queue", self.check_queue),
            ("Storage", self.check_storage),
            ("Memory", self.check_memory),
            ("CPU", self.check_cpu)
        ]
    
    async def run_health_check(self) -> dict:
        """Run all health checks"""
        results = {}
        
        for name, check_func in self.checks:
            try:
                status = await check_func()
                results[name] = {
                    "status": "healthy" if status.is_healthy else "unhealthy",
                    "message": status.message,
                    "metrics": status.metrics
                }
                
                # Auto-fix if unhealthy
                if not status.is_healthy:
                    fix_result = await self.auto_fix(name, status)
                    results[name]["fix_attempted"] = True
                    results[name]["fix_result"] = fix_result
                    
            except Exception as e:
                results[name] = {
                    "status": "error",
                    "message": str(e)
                }
        
        return results
```

