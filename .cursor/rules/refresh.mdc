        'name': str,
        'created_at': datetime
    }
    for field, expected_type in type_map.items():
        if field in fixed_data:
            fixed_data[field] = safe_convert(
                fixed_data[field], 
                expected_type,
                default=generate_default(field)
            )
    
    # Fix invalid formats
