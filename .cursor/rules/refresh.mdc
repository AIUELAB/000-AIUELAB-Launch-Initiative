## 🛠️ Fix Templates

### Quick Fix Patterns
```python
# Fix: Null/None handling
def safe_access(obj, *attrs, default=None):
    """Safely access nested attributes"""
    for attr in attrs:
        try:
            obj = getattr(obj, attr)
        except (AttributeError, TypeError):
            return default
    return obj

# Fix: Type conversion errors
def safe_convert(value, target_type, default=None):
    """Safely convert types"""
    try:
        return target_type(value)
    except (ValueError, TypeError):
        return default

# Fix: Division by zero
def safe_divide(numerator, denominator, default=0):
    """Safely divide numbers"""
    try:
        return numerator / denominator if denominator != 0 else default
    except (ZeroDivisionError, TypeError):
        return default

# Fix: List index out of range
def safe_index(lst, index, default=None):
    """Safely access list index"""
    try:
        return lst[index]
    except (IndexError, TypeError):
        return default

# Fix: Dictionary key errors
def safe_get(dictionary, key, default=None):
    """Safely get dictionary value"""
    if not isinstance(dictionary, dict):
        return default
    return dictionary.get(key, default)
```

