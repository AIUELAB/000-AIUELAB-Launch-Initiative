# Claude Code Docker Environment
# Provides isolated execution environment for --dangerously-skip-permissions

FROM node:22-slim AS base

# Install system dependencies
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-venv \
    git \
    curl \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install UV for Python package management
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.cargo/bin:${PATH}"

# Create non-root user for security
RUN useradd -m -s /bin/bash claude && \
    mkdir -p /home/claude/.npm-global && \
    chown -R claude:claude /home/claude

# Switch to non-root user
USER claude
WORKDIR /home/claude

# Configure npm for user installation
ENV NPM_CONFIG_PREFIX=/home/claude/.npm-global
ENV PATH="/home/claude/.npm-global/bin:${PATH}"

# Install Claude Code CLI
RUN npm install -g @anthropic/claude-cli

# Install MCP servers
RUN npm install -g \
    @modelcontextprotocol/server-filesystem \
    @modelcontextprotocol/server-github \
    @modelcontextprotocol/server-brave-search

# Create workspace directory
RUN mkdir -p /home/claude/workspace
WORKDIR /home/claude/workspace

# Copy entrypoint script
COPY --chown=claude:claude docker/entrypoint.sh /home/claude/entrypoint.sh
RUN chmod +x /home/claude/entrypoint.sh

# Set environment variables
ENV CLAUDE_HEADLESS=true
ENV CLAUDE_NO_TELEMETRY=true

# Entrypoint
ENTRYPOINT ["/home/claude/entrypoint.sh"]
CMD ["claude"]
