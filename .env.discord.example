# Discord 設定
# iOS Discord Tokyo & Love Swift コミュニティ

# Discord Bot Token
# https://discord.com/developers/applications でBot作成
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord サーバーID
DISCORD_IOS_TOKYO_SERVER_ID=1118089502259421214
DISCORD_LOVE_SWIFT_SERVER_ID=291054398077927425

# Discord Webhook URLs（各チャンネル用）
DISCORD_WEBHOOK_EVENTS=https://discord.com/api/webhooks/xxx/yyy
DISCORD_WEBHOOK_ANNOUNCEMENTS=https://discord.com/api/webhooks/xxx/yyy
DISCORD_WEBHOOK_JOBS=https://discord.com/api/webhooks/xxx/yyy

# Discord ユーザー情報
DISCORD_USER_ID=your_user_id
DISCORD_USERNAME=your_username

# Bot設定
DISCORD_BOT_PREFIX=!
DISCORD_BOT_NAME=AIUELAB Bot
DISCORD_BOT_STATUS=iOS Development

# 通知設定
DISCORD_NOTIFY_EVENTS=true
DISCORD_NOTIFY_MENTIONS=true
DISCORD_NOTIFY_DM=true

# 自動投稿設定
DISCORD_AUTO_POST=false
DISCORD_POST_SCHEDULE=0 10,16,22 * * *  # 10時、16時、22時

# チャンネルID（必要に応じて設定）
# iOS Discord Tokyo
IOS_TOKYO_GENERAL_CHANNEL=channel_id_here
IOS_TOKYO_EVENTS_CHANNEL=channel_id_here
IOS_TOKYO_SHOWCASE_CHANNEL=channel_id_here
IOS_TOKYO_JOBS_CHANNEL=channel_id_here

# Love Swift
LOVE_SWIFT_GENERAL_CHANNEL=channel_id_here
LOVE_SWIFT_EVENTS_CHANNEL=channel_id_here
LOVE_SWIFT_NEWS_CHANNEL=channel_id_here
