# Vercel 自動化設定
# このファイルを .env.vercel にコピーして、実際の値を設定してください

# Vercel アクセストークン
# 取得方法: https://vercel.com/account/tokens
VERCEL_TOKEN=your_vercel_token_here

# チーム/組織ID（オプション）
VERCEL_TEAM_ID=team_aiuelab

# プロジェクト設定
VERCEL_PROJECT_NAME=aiuelab
VERCEL_PROJECT_ID=your_project_id

# デプロイ設定
VERCEL_DOMAIN=aiuelab.com
VERCEL_ENV=production

# オプション設定
OPEN_BROWSER=false
AUTO_ALIAS=true
