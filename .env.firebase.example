# Firebase 設定
# アカウント: aiuelab.official@gmail.com

# Firebase プロジェクト
FIREBASE_PROJECT_ID=aiuelab-default
FIREBASE_PROJECT_NAME=AIUELAB

# Firebase認証
# firebase login:ci で取得
FIREBASE_TOKEN=your_firebase_ci_token_here

# Firebase Admin SDK (サーバー側で使用)
FIREBASE_ADMIN_SDK_KEY=your_admin_sdk_key_here

# Firebase設定
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=aiuelab-default.firebaseapp.com
FIREBASE_DATABASE_URL=https://aiuelab-default.firebaseio.com
FIREBASE_STORAGE_BUCKET=aiuelab-default.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
FIREBASE_APP_ID=your_app_id_here
FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# iOS アプリ設定
IOS_BUNDLE_ID_PREFIX=com.aiuelab
IOS_APP_STORE_ID=your_app_store_id_here
IOS_TEAM_ID=your_team_id_here

# プッシュ通知
FCM_SERVER_KEY=your_fcm_server_key_here
APNS_AUTH_KEY=your_apns_auth_key_here
APNS_KEY_ID=your_apns_key_id_here

# エミュレータ設定
FIREBASE_EMULATOR_HOST=localhost
FIRESTORE_EMULATOR_PORT=8080
AUTH_EMULATOR_PORT=9099
STORAGE_EMULATOR_PORT=9199
HOSTING_EMULATOR_PORT=5000

# 自動化設定
AUTO_DEPLOY=false
AUTO_BACKUP=true
BACKUP_SCHEDULE=0 3 * * *  # 毎日午前3時
